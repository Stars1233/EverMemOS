# EvoAgentBench environment variables
# Copy to .env and fill in your values

# OpenRouter API key (used by agent providers and deepresearch RACE evaluation)
OPENROUTER_API_KEY=sk-or-v1-xxx

# Jina API key (used by deepresearch FACT citation verification)
JINA_API_KEY=jina_xxx

# BrowseComp-Plus LLM Judge API key
JUDGE_API_KEY=sk-or-v1-xxx

# vLLM API key (if using local vLLM server)
VLLM_API_KEY=EMPTY

# Java (required for pyserini in BrowseComp-Plus)
JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64
